{
  "name": "pipi-tori-online",
  "version": "0.1.0",
  "description": "Online room-code prototype for ピッグ・ピック・トリック（ピピとり）",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "node tests/default_rules_regression.js && node tests/full_audit_regression.js && node tests/mobile_ui_regression.js && node tests/layout_collision_regression.js && node tests/source_integrity_regression.js",
    "test:ui": "node tests/mobile_ui_regression.js && node tests/layout_collision_regression.js",
    "test:layout": "node tests/layout_collision_regression.js",
    "test:smoke": "node tests/websocket_game_smoke.js",
    "test:reconnect": "node tests/reconnect_recovery_smoke.js",
    "test:resilience": "node tests/progress_resilience_smoke.js",
    "test:integrity": "node tests/source_integrity_regression.js",
    "test:fullgame": "node tests/four_human_completion_smoke.js"
