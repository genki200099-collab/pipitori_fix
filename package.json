  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "acorn": "^8.17.0",
    "css-tree": "^3.2.1",
    "parse5": "^8.0.1"
  },
  "engines": {
    "node": "22.x"
  }
